// prisma/schema.prisma
//
// This is the single source of truth for AkomaPlanner's data model.
// It compiles into a generated, fully-typed Prisma Client (src/generated or
// node_modules/.prisma) that src/lib/prisma.ts imports from.
//
// PORTABILITY: every field type used below (String, Int, Float, Boolean,
// DateTime, enum, relations) is standard Prisma and works identically on
// Postgres. The only SQLite-specific line is `provider = "sqlite"` below.
// Moving to hosted Postgres later (Neon/Supabase) means: change `provider`
// to "postgresql", point DATABASE_URL at the hosted connection string, and
// re-run `prisma db push` / `prisma migrate`. No model changes required.
// (SQLite doesn't support native enums or arrays — Prisma simulates enums
// as a checked String column on SQLite and will use a native Postgres enum
// automatically once the provider changes. See LEARNING.md for detail.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum City {
  ACCRA
  KUMASI
  OTHER
}

enum MemberRole {
  OWNER // the account that created the wedding plan
  PARTNER // fiancé(e) invited as a collaborator
  PLANNER // professional/family planner invited as a collaborator
  COLLABORATOR // generic collaborator (e.g. parent helping plan)
}

enum Side {
  BRIDE
  GROOM
  BOTH
}

enum RsvpStatus {
  PENDING
  YES
  NO
}

enum VendorCategory {
  VENUE
  CATERING
  PHOTOGRAPHY
  ATTIRE
  DECOR
  MUSIC
  MAKEUP
  TRANSPORT
  CAKE
  OTHER
  JEWELLERY
  MC
  PLANNER
}

// Lifecycle of a couple's interest in a vendor. This enum is the backbone of
// the "draft-and-approve, never autonomous" safety rule: BisaAI-authored
// content can only ever create/update rows up to SENT. Only an explicit
// human action in a server action (never a BisaAI function) may set a row to
// ACCEPTED.
enum VendorInterestStatus {
  DRAFT // BisaAI (or the couple) drafted an enquiry/negotiation message; nothing sent yet
  SENT // couple explicitly tapped "Send"
  QUOTED // vendor responded with a quote (entered manually for MVP)
  ACCEPTED // couple explicitly approved the quote — a human-only transition
  DECLINED
}

// The couple's real-world progress with one vendor — deliberately
// independent of VendorInterestStatus above. That enum tracks the state
// of an in-app AI-drafted enquiry/quote artifact; this one tracks "where
// am I in the process of securing this vendor," which is just as often
// answered entirely outside the app (a phone call, WhatsApp, a wedding
// fair) as through it. See lib/vendor-booking-progress.ts for the rank
// ordering (Prisma/SQLite enums are checked strings with no ordinal
// guarantee — never rely on declaration order here for comparisons).
enum VendorBookingProgress {
  NOT_CONTACTED
  SHORTLISTED
  ENQUIRY_SENT
  MEETING_SCHEDULED
  NEGOTIATING
  BOOKED
  NOT_SELECTED
}

// ---------------------------------------------------------------------------
// Identity & membership
// ---------------------------------------------------------------------------

// A person with an account. Real authentication (email/password + Google)
// is handled entirely by Supabase Auth, not this table — this row is this
// app's own record of the wedding-planning data a Supabase identity owns,
// joined to it via supabaseId. See src/lib/supabase/sync-user.ts for the
// one place a Supabase identity becomes/updates a row here.
model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  // Links this row to a real Supabase Auth identity (auth.users.id, a
  // uuid) — see src/lib/supabase/sync-user.ts. Supabase is the identity
  // provider; this app's own data (WeddingPlan, Guest, ...) stays in this
  // local database, joined to Supabase only through this column.
  supabaseId        String   @unique
  // No longer written for new users — Supabase owns password storage now.
  // Kept nullable for the historical seeded row / backward compatibility
  // only; see src/lib/supabase/sync-user.ts.
  passwordHash      String?
  // Synced from Supabase's real app_metadata.provider ("email" or
  // "google") on every sign-in — see sync-user.ts.
  authProvider      String   @default("email")
  // Synced from Supabase's real email_confirmed_at — a genuine
  // verification state now, not a demo flag.
  emailVerified     Boolean  @default(false)
  // Path under /public (e.g. "/uploads/avatars/<id>-<ts>.jpg") written by
  // the upload route handler — see src/app/api/upload/avatar/route.ts for
  // why this is local-disk storage for now, not a real object-storage URL.
  // For a Google account, synced from Supabase's avatar_url instead (see
  // sync-user.ts) until the user uploads their own.
  profilePictureUrl String?
  // First-time guided product tour (see src/components/tour/) — true once
  // skipped or completed; Settings has a control to flip this back to
  // false and re-trigger it.
  hasCompletedTour  Boolean  @default(false)
  createdAt         DateTime @default(now())

  ownedWeddingPlans WeddingPlan[]   @relation("WeddingOwner")
  memberships       WeddingMember[]
}

// Join table between User and WeddingPlan. Having this as its own model
// (rather than a single ownerId on WeddingPlan) is what lets Collaboration
// (Pass) add a fiancé/planner later without any schema change — the seam
// already exists even though the MVP UI only exercises the OWNER role.
model WeddingMember {
  id            String      @id @default(cuid())
  role          MemberRole
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, weddingPlanId])
}

// ---------------------------------------------------------------------------
// Core wedding plan
// ---------------------------------------------------------------------------

// The central object every other feature hangs off. One row per wedding.
// Free accounts are limited to one WeddingPlan; that limit is enforced in
// src/lib/plan.ts (application logic), not here — the schema itself has no
// opinion on how many a user may create.
model WeddingPlan {
  id             String   @id @default(cuid())
  coupleNames    String // e.g. "Ama & Kwame" — free text, kept simple for MVP
  weddingDate    DateTime
  totalBudgetGHS Float
  city           City
  guestEstimate  Int
  tradition      String // free text, e.g. "Akan", "Ewe", "Interfaith" — not an enum, traditions are too varied to whitelist
  // One field, one meaning: paid once (see the Wedding Pass — a one-time
  // GH¢300 purchase, not a subscription), has full access forever. No
  // renewal/expiry concept — see lib/plan.ts's single canAccessPassFeatures()
  // helper, the one place this field is ever read for gating.
  hasWeddingPass Boolean  @default(false)

  // Non-guessable token used to build the public read-only share URL
  // (/w/[shareToken]). Regenerable from settings if it ever leaks.
  shareToken String @unique @default(cuid())

  // Which Design Tools invitation template the couple has picked, by id
  // (see lib/invitation-templates.ts — the static registry this points
  // into; not a foreign key, since templates aren't a DB table). Nullable:
  // no template chosen yet is a valid, common state.
  selectedInvitationTemplateId String?

  ownerUserId String
  owner       User   @relation("WeddingOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  members                  WeddingMember[]
  budgetCategories         BudgetCategory[]
  checklistItems           ChecklistItem[]
  guests                   Guest[]
  vendorInterests          VendorInterest[]
  aiLogs                   AIInteractionLog[]
  coupleProfile            CoupleProfile?
  vendorBookingStatuses    VendorBookingStatus[]
  notifications            Notification[]
  payments                 Payment[]
  timelineEntries          TimelineEntry[]
  seatingAssignments       SeatingAssignment[]
  traditionalCeremonyItems TraditionalCeremonyItem[]
  honeymoonPlan            HoneymoonPlan?
  honeymoonChecklistItems  HoneymoonChecklistItem[]
  documents                WeddingDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One row per payment attempt for the Wedding Pass — a real audit trail
// (nothing like this existed for the old stubbed-subscription checkout).
// `reference` is the provider's (Paystack) transaction reference, unique
// so the webhook can safely upsert on it — a retried webhook delivery for
// the same reference is a no-op, not a double-charge. `status` starts
// PENDING when checkout redirects to the provider, and only becomes
// SUCCESS from a server-verified confirmation (webhook or a server-side
// verify call) — never from the browser alone. See Workstream C.
model Payment {
  id            String        @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan   @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  provider      String // e.g. "paystack"
  reference     String        @unique
  amountGHS     Float
  currency      String        @default("GHS")
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// Onboarding profile (everything the wizard collects beyond WeddingPlan's
// original 6 core fields — kept in its own table rather than bloating
// WeddingPlan, so every existing read of weddingPlan.coupleNames/weddingDate/
// etc. keeps working untouched. One row per wedding, all fields optional
// since a couple can always fill more in later from /profile.)
// ---------------------------------------------------------------------------

enum IndoorOutdoor {
  INDOOR
  OUTDOOR
  BOTH
}

enum WeddingType {
  TRADITIONAL
  WHITE_WEDDING
  CIVIL
  DESTINATION
  MULTIPLE_CEREMONIES
}

enum BudgetFlexibility {
  STRICT
  SOMEWHAT_FLEXIBLE
  VERY_FLEXIBLE
}

enum PlanningExperience {
  FIRST_TIME
  PLANNED_BEFORE
  HIRING_A_PLANNER
}

enum DiyVsProfessional {
  MOSTLY_DIY
  MOSTLY_PROFESSIONAL
  A_MIX
}

enum CommunicationStyle {
  DETAILED_EXPLANATIONS
  QUICK_SUMMARIES
  WEEKLY_CHECK_IN
}

model CoupleProfile {
  id            String      @id @default(cuid())
  weddingPlanId String      @unique
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)

  // Couple information — partner1's email/phone live on the account (User),
  // these cover the second partner plus how the couple wants to be addressed.
  partner1Name  String?
  partner2Name  String?
  displayName1  String?
  displayName2  String?
  partner1Phone String?
  partner2Phone String?
  partner2Email String?

  // Wedding details beyond WeddingPlan.weddingDate (the "tentative" date).
  ceremonyDate  DateTime?
  receptionDate DateTime?
  venueName     String?
  indoorOutdoor IndoorOutdoor?
  weddingType   WeddingType?

  // Guest information beyond WeddingPlan.guestEstimate.
  bridalPartySize Int?
  groomPartySize  Int?

  // Budget — isDiaspora replaces a currency selector: the app stays
  // GHS-only (see lib/currency.ts), this just flags a couple planning from
  // abroad so BisaAI/future features can account for that context.
  budgetFlexibility BudgetFlexibility?
  isDiaspora        Boolean            @default(false)

  // Wedding style — informational personalization only (see
  // dashboard/page.tsx's "Your wedding style" card); never used to re-skin
  // the app's own chrome or charts. primaryColor/secondaryColor are hex
  // strings (e.g. "#D4A017") chosen via a real color picker or a preset
  // palette (see lib/wedding-palettes.ts) — replaced the old free-text
  // colorPalette field so the dashboard swatch is a real color, not a
  // guess parsed from a color-name string.
  theme          String?
  primaryColor   String?
  secondaryColor String?
  dressCode      String?
  visionNotes    String?
  pinterestUrl   String?

  // Planning preferences.
  biggestConcern            String?
  planningExperience        PlanningExperience?
  diyVsProfessional         DiyVsProfessional?
  needVendorRecommendations Boolean             @default(true)
  needTimelineAssistance    Boolean             @default(true)
  communicationStyle        CommunicationStyle?

  // Relationship.
  proposalDate   DateTime?
  engagementDate DateTime?
  loveStory      String?

  // Additional notes.
  specialRequests               String?
  accessibilityRequirements     String?
  culturalReligiousRequirements String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A separate, purpose-built category list for the onboarding "have you
// booked this yet?" checklist — deliberately NOT the same enum as
// VendorCategory (which drives the real Vendor catalog/seed data and
// doesn't split out Videographer/DJ/MC/Planner/Bridal/Groom's/Jewellery
// the way this list does). Changing that enum to match would ripple
// through the whole vendor-browsing feature for a much smaller
// self-reported checklist. The 14 values here are the app's standardized
// primary vendor categories (see lib/validation/wedding.ts's
// ONBOARDING_VENDOR_CATEGORIES for display labels/ordering — member names
// here are stable identifiers, not the display text).
enum OnboardingVendorCategory {
  VENUE
  PHOTOGRAPHER
  VIDEOGRAPHER
  CATERER
  DECOR
  PLANNER
  DJ_BAND
  MC
  BRIDAL_WEAR
  GROOMS_WEAR
  MAKEUP
  JEWELLERY
  CAKE
  TRANSPORTATION
}

enum BookingStatus {
  NOT_STARTED
  RESEARCHING
  BOOKED
}

model VendorBookingStatus {
  id            String                   @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan              @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  category      OnboardingVendorCategory
  status        BookingStatus            @default(NOT_STARTED)
  updatedAt     DateTime                 @updatedAt

  @@unique([weddingPlanId, category])
}

// ---------------------------------------------------------------------------
// Budget
// ---------------------------------------------------------------------------

// One row per spending category (Venue, Catering, Attire, ...). The budget
// calculator in src/lib/budget.ts aggregates these against
// WeddingPlan.totalBudgetGHS — the math itself lives in code, not the schema,
// so it stays unit-testable without a database.
model BudgetCategory {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  name          String
  allocatedGHS  Float
  spentGHS      Float       @default(0)
  createdAt     DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// Checklist
// ---------------------------------------------------------------------------

model ChecklistItem {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  title         String
  category      String
  // Shown in the calendar's task-detail popup alongside a static,
  // category-keyed "planning tip" (not stored here — see
  // CATEGORY_TIPS in checklist-defaults.ts). Real, written descriptions
  // for every default template item; blank for custom user-added tasks.
  description   String?
  dueDate       DateTime?
  done          Boolean     @default(false)
  // Seeded from the default Ghana wedding checklist template vs. added by
  // the couple themselves — lets the UI show "default" items differently
  // from custom ones if we want to.
  isDefault     Boolean     @default(false)
  // Drives the Checklist page's priority badge and the Dashboard's
  // "This week's focus" list (HIGH + not done, soonest due date first).
  // Defaults to MEDIUM so existing rows and quickly-added tasks don't
  // need a decision up front.
  priority      Priority    @default(MEDIUM)
  createdAt     DateTime    @default(now())
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ---------------------------------------------------------------------------
// Guests
// ---------------------------------------------------------------------------

model Guest {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  name          String
  side          Side
  rsvpStatus    RsvpStatus  @default(PENDING)
  contact       String?
  plusOne       Boolean     @default(false)
  // Free-form relationship tag for the seating chart's grouping tools
  // (src/components/design/) — nullable, set from either the Guest List
  // page or in-context within the seating tool itself, both via the same
  // updateGuestGroup() action. Lives on Guest rather than a seating-only
  // side table: one nullable field, and it makes the tag visible/
  // reusable on the Guest List page too, not just in the seating tool.
  guestGroup    GuestGroup?
  createdAt     DateTime    @default(now())

  seatingAssignment SeatingAssignment?
}

enum GuestGroup {
  BRIDE_FAMILY
  GROOM_FAMILY
  BRIDESMAID
  GROOMSMAN
  VIP
  PARENT
  CHILD
}

// ---------------------------------------------------------------------------
// Vendors
// ---------------------------------------------------------------------------

// Vendor listings are global (not per-wedding) — every couple browses the
// same catalog, seeded with sample Accra/Kumasi vendors.
model Vendor {
  id            String         @id @default(cuid())
  name          String
  category      VendorCategory
  city          City
  description   String
  priceLowGHS   Float
  priceHighGHS  Float
  rating        Float          @default(4.5)
  contactPhone  String?
  contactEmail  String?
  // Featured listings are still visible to Free users (browsable) but
  // interactions with them (save quote, compare, message) are gated by
  // requirePass() — enforced in application code, not here.
  isProFeatured Boolean        @default(false)
  imageUrl      String?

  vendorInterests VendorInterest[]
  accommodations  Accommodation[]
  createdAt       DateTime         @default(now())
}

// Tracks a couple's negotiation lifecycle with one vendor. This is the
// concrete implementation of the "draft-and-approve, never autonomous"
// rule — see the VendorInterestStatus enum comment above for the invariant.
model VendorInterest {
  id                 String                    @id @default(cuid())
  weddingPlanId      String
  weddingPlan        WeddingPlan               @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  vendorId           String
  vendor             Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status             VendorInterestStatus      @default(DRAFT)
  draftMessage       String? // BisaAI-authored or hand-written enquiry/negotiation text, pre-send
  quoteAmountGHS     Float? // entered once the vendor responds (manual for MVP)
  notes              String?
  // Real-world booking progress (see VendorBookingProgress's own comment)
  // and which of the 12 onboarding categories it counts against — set by
  // the ungated setVendorBookingProgress action (server/actions/vendor-booking.ts),
  // never by anything in lib/bisaai.ts. Nullable: ATTIRE/OTHER vendors
  // (VendorCategory values) have no OnboardingVendorCategory equivalent
  // at all, so "not tracked as a booking category" is a real, distinct
  // state from "not yet chosen."
  bookingProgress    VendorBookingProgress     @default(NOT_CONTACTED)
  onboardingCategory OnboardingVendorCategory?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@unique([weddingPlanId, vendorId])
}

// ---------------------------------------------------------------------------
// Traditional list (global reference data, not per-wedding)
// ---------------------------------------------------------------------------

// Sample items for Ghanaian traditional/engagement lists (drinks, kente,
// gifts for family, etc.) with ESTIMATED price ranges and a market
// reference. Every price field here is explicitly a range, never a single
// "quote" number — reinforces that this is estimate-only data (safe rule #3).
model TraditionalListItem {
  id         String   @id @default(cuid())
  category   String // e.g. "Drinks", "Kente & Cloth", "Gifts for Family"
  itemName   String
  estLowGHS  Float
  estHighGHS Float
  market     String // e.g. "Kejetia Market, Kumasi"
  city       City
  notes      String?
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Traditional Ceremony (per-couple, Pass feature) — the trackable workspace
// TraditionalListItem above feeds as one-time seed data for. Deliberately a
// separate model, not a rename: TraditionalListItem is global catalog data
// with no acquired/spent concept at all; this is per-wedding, editable, and
// syncs its aggregate spentGHS onto the "Traditional Customary"
// BudgetCategory (see lib/budget-defaults.ts and
// server/actions/traditional-ceremony.ts for the sync direction).
model TraditionalCeremonyItem {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  name          String
  category      String
  allocatedGHS  Float       @default(0)
  spentGHS      Float       @default(0)
  done          Boolean     @default(false)
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// ---------------------------------------------------------------------------
// Accommodation (global reference data, linked loosely to a nearby vendor
// venue for "distance from venue" context)
// ---------------------------------------------------------------------------

model Accommodation {
  id                  String   @id @default(cuid())
  name                String
  city                City
  distanceFromVenueKm Float
  priceLowGHS         Float
  priceHighGHS        Float
  contactPhone        String?
  description         String?
  rating              Float    @default(4.5)
  // Comma-separated, same simple-list convention as other free-text
  // fields in this schema (see WeddingPlan.tradition) — a real amenities
  // taxonomy is more structure than an MVP booking-adjacent list needs.
  amenities           String?
  // A real uploaded photo if one exists; otherwise a placeholder is
  // chosen from a small rotating set (see lib/accommodation-images.ts) —
  // same "real photo wins, else a category/type placeholder" pattern as
  // Vendor.imageUrl.
  imageUrl            String?
  // Loosely associated with a sample venue vendor so distance has meaning
  // in the seed data; nullable because not every accommodation needs one.
  nearVendorId        String?
  nearVendor          Vendor?  @relation(fields: [nearVendorId], references: [id])
  createdAt           DateTime @default(now())
}

// ---------------------------------------------------------------------------
// AI audit trail
// ---------------------------------------------------------------------------

// One row per BisaAI function call. Not asked for explicitly, but cheap to
// add and gives us (a) a visible audit trail that nothing was ever
// auto-sent on the couple's behalf, and (b) a realistic look at how
// production AI products log usage. isMock is always true today since
// every lib/bisaai.ts function is a mock — flips to false once a real
// model call replaces a given function.
model AIInteractionLog {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  functionName  String // e.g. "draftVendorMessage", "priceTraditionalList"
  inputSummary  String
  outputSummary String
  isMock        Boolean     @default(true)
  createdAt     DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

enum NotificationType {
  TASK
  GUEST
  BUDGET
  WEDDING
  VENDOR
  SYSTEM
}

// One row per notification, real (not computed-on-render), so "mark as
// read" actually persists. Two kinds of writer, both going through the
// same createNotification() helper in src/lib/notifications.ts:
//   1. Event-based — written once, at the moment something happens (e.g.
//      "Welcome to Akoma Planner" from createWeddingPlan()).
//   2. State-derived — re-synced from live data (budget %, pending
//      RSVPs, vendor booking status, countdown milestones) every time
//      syncComputedNotifications() runs. `key` is what makes that safe:
//      it's a stable, semantic id (e.g. "budget-over",
//      "vendor-PHOTOGRAPHER-not-booked") that a re-sync upserts against,
//      refreshing only the message text — isRead and createdAt are never
//      touched by an update, so marking something read actually sticks.
// createNotification() is also the one seam a future email/WhatsApp/
// Telegram/push/SMS dispatch would hook into — not built now, just left
// obvious, same as the real-provider swap points in billing.ts/bisaai.ts.
model Notification {
  id            String           @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan      @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  key           String
  type          NotificationType
  message       String
  actionHref    String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  @@unique([weddingPlanId, key])
}

// ---------------------------------------------------------------------------
// Design Tools (Pass): persisted timeline + seating chart
// ---------------------------------------------------------------------------

// The wedding-day timeline, editable and auto-saved — a real change from
// how this worked before (generateTimeline() in lib/bisaai.ts computed a
// fresh default every render, nothing persisted). getOrCreateTimeline()
// (server/actions/timeline.ts) seeds these rows from that same default
// template on first access; every row after that reflects the couple's
// own edits. No @@unique on sortOrder deliberately — the reorder
// swap (two adjacent rows exchanging sortOrder in one transaction) would
// risk a transient collision against a hard constraint on SQLite, which
// checks UNIQUE per-statement, not deferred to end-of-transaction.
model TimelineEntry {
  id              String      @id @default(cuid())
  weddingPlanId   String
  weddingPlan     WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  time            String // "HH:MM", same convention generateTimeline() already used
  activity        String
  durationMinutes Int
  sortOrder       Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([weddingPlanId, sortOrder])
}

// Which table a confirmed guest is assigned to — also new persistence
// (seatingSuggestions() in lib/bisaai.ts used to compute a fresh
// suggestion every render, nothing saved). One row per guest max
// (@unique on guestId): a guest can only be at one table at a time, and
// re-assigning is an update, not a second row.
model SeatingAssignment {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  guestId       String      @unique
  guest         Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tableNumber   Int
  updatedAt     DateTime    @updatedAt
}

// ---------------------------------------------------------------------------
// Honeymoon Planner (Pass feature) — deliberately standalone from the main
// wedding budget/checklist. One HoneymoonPlan per wedding (destination,
// style, its own budget); a small fixed default checklist seeded once at
// createWeddingPlan time, same as ChecklistItem's own default template.
// ---------------------------------------------------------------------------

model HoneymoonPlan {
  id            String      @id @default(cuid())
  weddingPlanId String      @unique
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  destination   String? // Ghana-preset region name or free-text international destination
  styles        String // comma-separated (SQLite has no array type) — same precedent as Accommodation.amenities
  allocatedGHS  Float       @default(0)
  spentGHS      Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model HoneymoonChecklistItem {
  id            String      @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  title         String
  done          Boolean     @default(false)
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// Documents Vault (Pass feature) — stores an object path in Supabase
// Storage, not a durable public URL, since these can be sensitive
// (contracts, receipts). See lib/supabase/storage.ts for why this needs a
// service-role client rather than the regular per-request Supabase client.
// ---------------------------------------------------------------------------

enum DocumentCategory {
  VENDORS
  FINANCE
  LEGAL
  GUESTS
  OTHER
}

model WeddingDocument {
  id            String           @id @default(cuid())
  weddingPlanId String
  weddingPlan   WeddingPlan      @relation(fields: [weddingPlanId], references: [id], onDelete: Cascade)
  name          String
  category      DocumentCategory @default(OTHER)
  storagePath   String
  fileType      String
  fileSizeBytes Int
  createdAt     DateTime         @default(now())
}
